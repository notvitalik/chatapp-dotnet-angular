{
  "ConnectionStrings": {
    "ChatAppDatabase": "ReplaceThisWithYourConnectionStringOrUseUserSecrets"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:4200"
    ]
  },
  "Jwt": {
    "Issuer": "ChatApp",
    "Audience": "ChatApp.Client",
    "SigningKey": "ReplaceThisWithASecretFromUserSecretsOrEnvironmentVariables",
    "ExpirationMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
